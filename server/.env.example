# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Allowed frontend origin (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/pushdoc?retryWrites=true&w=majority

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── GitHub OAuth App ─────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://yourdomain.com/auth/github/callback

# ── GitHub App (for installation & webhooks) ─────────────────
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── AI Keys (at least one Gemini or Groq key required) ───────
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

GROQ_API_KEY_1=
GROQ_API_KEY_2=

# ── Workspace (where cloned repos are temporarily stored) ────
# Use an absolute path on the server — e.g. /var/pushdoc/workspaces
# Leave blank to use the default: ./temp/workspaces
WORKSPACE_ROOT_PATH=
